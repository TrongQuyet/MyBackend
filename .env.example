# App
APP_PORT=3000
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=my_backend

# JWT
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Media Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
UPLOAD_STORAGE_PROVIDER=local

# AWS S3 (only needed when UPLOAD_STORAGE_PROVIDER=s3)
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=1000

# CORS
CORS_ORIGIN=*
